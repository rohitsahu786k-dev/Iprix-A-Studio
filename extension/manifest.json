{
   "action": {
      "default_icon": {
         "128": "aplus-studio-logo.png",
         "16": "aplus-studio-logo.png",
         "32": "aplus-studio-logo.png",
         "48": "aplus-studio-logo.png"
      },
      "default_title": "A+ Studio"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "_execute_action": {
         "suggested_key": {
            "default": "Alt+Shift+L",
            "mac": "Alt+Shift+L"
         },
         "description": "Open the A+ Studio sidebar"
      }
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "logger.js" ],
      "matches": [ "*://*.meesho.com/*", "*://seller.flipkart.com/*", "https://sellercentral.amazon.in/*", "https://aplusstudio.iprixmedia.com/*", "https://iprixmedia.com/*", "http://localhost:3000/*", "http://localhost:3457/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "content-script.js" ],
      "matches": [ "*://*.meesho.com/*", "*://seller.flipkart.com/*", "https://sellercentral.amazon.in/*", "https://aplusstudio.iprixmedia.com/*", "https://iprixmedia.com/*", "http://localhost:3000/*", "http://localhost:3457/*" ]
   }, {
      "all_frames": false,
      "js": [ "meesho-guard.js" ],
      "matches": [ "*://supplier.meesho.com/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": false,
      "js": [ "platforms/meesho/low-shipping.js" ],
      "matches": [ "*://supplier.meesho.com/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": false,
      "js": [ "platforms/flipkart/fk-category.js" ],
      "matches": [ "*://seller.flipkart.com/*" ]
   }, {
      "all_frames": true,
      "js": [ "platforms/flipkart/fk-fill.js" ],
      "matches": [ "*://seller.flipkart.com/*" ]
   }, {
      "all_frames": false,
      "js": [ "platforms/flipkart/fk-autofill.js" ],
      "matches": [ "*://seller.flipkart.com/*" ]
   }, {
      "all_frames": false,
      "js": [ "platforms/flipkart/fk-buttons.js" ],
      "matches": [ "*://seller.flipkart.com/*" ]
   } ],
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "fix_image_origin",
         "path": "rules.json"
      } ]
   },
   "description": "AI listing autofill studio for Indian sellers by Iprix Media.",
   "host_permissions": [ "https://aplusstudio.iprixmedia.com/*", "https://iprixmedia.com/*", "http://localhost:3000/*", "http://localhost:3457/*", "*://seller.flipkart.com/*", "https://sellercentral.amazon.in/*", "*://supplier.meesho.com/*", "*://*.meesho.com/*", "https://messho-images.picckie.com/*" ],
   "icons": {
      "128": "aplus-studio-logo.png",
      "16": "aplus-studio-logo.png",
      "32": "aplus-studio-logo.png",
      "48": "aplus-studio-logo.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "A+ Studio",
   "permissions": [ "activeTab", "scripting", "storage", "unlimitedStorage", "tabs", "windows", "declarativeNetRequest", "cookies", "alarms", "notifications" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.5.0",
   "web_accessible_resources": [ {
      "matches": [ "<all_urls>" ],
      "resources": [ "popup/popup.html", "popup/popup.js", "popup/xlsx.mini.min.js", "popup/flipkart/fk-tab.js", "config.js", "fonts/inter-latin.woff2", "aplus-studio-logo.png" ]
   } ]
}
